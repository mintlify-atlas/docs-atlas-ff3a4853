  "keyFeatures": [
    "ZK Compression for rent-free state storage on Solana",
    "Compressed tokens compatible with SPL Token standard",
    "Compressed PDAs with program-derived addresses",
    "Batched Merkle trees with ZK proof verification",
    "TypeScript and Rust SDKs for client and program development",
    "CLI tools for local development and testing",
    "Off-chain ZK prover service with Groth16 SNARKs",
    "Forester nodes for asynchronous queue management"
  ],
  "publicApiSurface": [
    "@lightprotocol/stateless.js - JavaScript SDK for compressed accounts",
    "@lightprotocol/compressed-token - JavaScript SDK for compressed tokens",
    "@lightprotocol/zk-compression-cli - CLI tool for development",
    "light-sdk - Rust SDK for program integration",
    "light-client - Rust client for RPC queries",
    "light-compressed-token - Compressed token program",
    "light-system-program - Compressed account validation program",
    "account-compression - Core compression program",
    "light-registry - Protocol configuration program",
    "light-prover-client - Rust client for ZK proof generation"
